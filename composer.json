{
    "name": "kadonix/laravel-swagger-routebook",
    "description": "A tiny route-first Swagger documentation package for Laravel.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Kadonix\\Routebook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kadonix\\Routebook\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kadonix\\Routebook\\RoutebookServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
